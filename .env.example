# Thepla House — environment variables
# Copy to .env.local (local) or set in your hosting provider (Vercel) for production.

# --- SMTP email (contact / catering / franchise enquiry forms) ---
# Same pattern as opsy: nodemailer over SMTP.
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false            # "true" for port 465, "false" for 587/STARTTLS
SMTP_USER=
SMTP_PASS=
EMAIL_FROM="Thepla House <noreply@theplahouse.com>"

# Where ALL website enquiries (catering, franchise, contact) are delivered
# (comma-separated). The enquirer also gets a confirmation email automatically.
ENQUIRY_EMAILS=management@theplahouse.com,dhaval@datagami.in

# --- Anti-spam: Cloudflare Turnstile (enquiry forms) ---
# Free keys from https://dash.cloudflare.com/?to=/:account/turnstile
# If unset, CAPTCHA is skipped (forms still work — honeypot + rate-limit remain).
# Local "always-pass" test keys:
#   site:   1x00000000000000000000AA
#   secret: 1x0000000000000000000000000000000AA
NEXT_PUBLIC_TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=

# --- SEO ---
# Google Search Console verification token (optional).
NEXT_PUBLIC_GOOGLE_SITE_VERIFICATION=

# Thepla House — environment variables
# Copy to .env.local (local) or set in your hosting provider (Vercel) for production.

# --- SMTP email (contact / catering / franchise enquiry forms) ---
# Same pattern as opsy: nodemailer over SMTP.
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false            # "true" for port 465, "false" for 587/STARTTLS
SMTP_USER=
SMTP_PASS=
EMAIL_FROM="Thepla House <noreply@theplahouse.com>"

# Where website enquiries are delivered (comma-separated). Franchise enquiries
# are also sent to the franchise contact automatically.
ENQUIRY_EMAILS=info@theplahouse.com

# --- SEO ---
# Google Search Console verification token (optional).
NEXT_PUBLIC_GOOGLE_SITE_VERIFICATION=
